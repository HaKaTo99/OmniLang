{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "OmniLang",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#decorators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "//.*$",
                    "name": "comment.line.double-slash.omnilang"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(let|mut|if|else|while|for|return|match|in|true|false)\\b",
                    "name": "keyword.control.omnilang"
                },
                {
                    "match": "\\b(INTENT|ACTOR|CONTEXT|ASSUMPTION|RULE|CONSTRAINT|IMPACT|TRACE|REVIEW):",
                    "name": "keyword.other.omnilang"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.omnilang",
                    "patterns": [
                        {
                            "match": "\\\\.",
                            "name": "constant.character.escape.omnilang"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
                    "name": "constant.numeric.omnilang"
                }
            ]
        },
        "decorators": {
            "patterns": [
                {
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
                    "name": "entity.name.function.decorator.omnilang"
                }
            ]
        }
    },
    "scopeName": "source.omni"
}